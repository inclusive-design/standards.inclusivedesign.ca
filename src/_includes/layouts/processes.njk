{% extends "layouts/base.njk" %}

{% set pageType = 'processes' %}

{% block content %}
<nav aria-labelledby="processes-menu" class="flow sidebar-menu">
    <inclusive-disclosure>
        <button aria-controls="{{ title | slugify }}-menu">
            <h2 class="h3" id="processes-menu">{% __ 'toc' %}</h2>
        </button>
        <div content id="{{ title | slugify }}-menu">
            <ul role="list" class="flow">
                <li class="flow" id="toc">
                        <h3>{% __ 'toc' %}</h3>
                    <ul role="list" class="flow">
                    </ul>
                </li>
            </ul>
        </div>
    </inclusive-disclosure>
</nav>
<article>
	{% set stages = collections['stages_' + lang] %}
	{% for stage in stages %}
	<section>
		{% include '../../_includes/svg/stage-' + stage.data.order + '.svg' %}
		<div class="flow">
			<h2>{{ stage.data.title }}</h2>
			{{ stage.content | safe }}
			<div class="cards">
				{% set processes = collections['processes_' + lang] | findAll('data.stage', stage.data.uuid) %}
				{% for process in processes %}
					{% include 'partials/components/card--process.njk' %}
				{% endfor %}
			</div>
		</div>
	</section>
	{% endfor %}

</article>
{% endblock %}
