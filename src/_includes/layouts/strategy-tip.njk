{% extends "layouts/base.njk" %}

{% set pageType = 'strategy-tip' %}

{% block banner %}
<div class="banner">
    <div class="wrapper">
        <div class="banner__content flow">
        	{% set breadcrumb = collections['pages_' + lang] | find('data.translationKey', 'processes') %}
            <a href="{{ breadcrumb.url }}" >{{ breadcrumb.data.shortTitle if breadcrumb.data.shortTitle else breadcrumb.data.title }} {% include 'svg/arrowRight.svg' %}</a>
            <h1>{{ title }}</h1>
            <div class="strategy-processes">
                {% __ 'strategies-for' %}
            {% for strategyId in processes %}
                {% if processes | length > 1 %}
                {{ 'and' if loop.last }}
                {% endif %}
                {% set process = collections['processes_' + lang] | find('data.uuid', strategyId) %}
                {% include '../../assets/images/' + process.data.translationKey + '.svg' %}
                <a href="{{ process.url }}">{{ process.data.title }}</a>
                {{ ',' if not loop.last }}
            {% endfor %}
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block content %}
{% set targetBarriers = [] %}
{% for uuid in barriers %}
    {% set targetBarriers = targetBarriers.concat(collections['barriers_' + lang] | find('data.uuid', uuid)) %}
{% endfor %}
<nav aria-labelledby="strategy-menu" class="flow">
    <inclusive-disclosure>
        <button aria-controls="{{ title | slugify }}-menu">
            <h2 id="strategy-menu">{% __ 'toc' %}</h2>
        </button>
        <div content id="{{ title | slugify }}-menu">
            <ul role="list" class="flow">
                <li class="flow" id="toc">
                        <h3>{% __ 'toc' %}</h3>
                    <ul role="list" class="flow">
                    </ul>
                <ul role="list" class="flow strategies-target-barriers">
                        {% for barrier in targetBarriers %}
                            <li><a href="#{{ barrier.data.title }}">{{ barrier.data.title }}</a></li>
                        {% endfor %}
                    </ul>
                </li>
            </ul>
        </div>
    </inclusive-disclosure>
</nav>
<article class="flow">
{% if strategies %}
    <h2>{% __ 'strategies-and-tips-strategies' %}</h2>
    {{ strategies | markdown | safe }}
{% endif %}
{% if tips %}
    <h2>{% __ 'strategies-and-tips-tips' %}</h2>
    {{ tips | markdown | safe }}
{% endif %}
{% if moreInformation %}
    <h2>{% __ 'strategies-and-tips-more-info' %}</h2>
    {{ moreInformation | markdown | safe }}
{% endif %}
{% if examples %}
    <h2>{% __ 'strategies-and-tips-examples' %}</h2>
    {{ examples | markdown | safe }}
{% endif %}
{% if barriers %}
<h2>{% __ 'strategies-and-tips-barriers' %}</h2>
{% for barrier in targetBarriers %}
    {% include "partials/components/card--barrier.njk" %}
{% endfor %}
{% endif %}
</article>
{% endblock %}
