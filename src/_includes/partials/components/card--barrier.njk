{% set relatedStrategiesAndTips = collections["strategies-and-tips_" + lang] | findAll('data.barriers', barrier.data.uuid) %}
{% set relatedProcessUuids = [] %}
{% set relatedProcesses = [] %}
{% for strategy in relatedStrategiesAndTips %}
	{% set relatedProcessUuids = relatedProcessUuids.concat(strategy.data.processes) %}
{% endfor %}
{% for relatedProcessUuid in relatedProcessUuids %}
	{% set relatedProcess = collections['processes_' + lang] | find('data.uuid', relatedProcessUuid) %}
	{% set relatedProcesses = relatedProcesses.concat([relatedProcess]) %}
{% endfor %}

<div class="card barrier bg-indigo-700" data-filter-stages="{% for process in relatedProcesses %}{{ process.data.stage }},{% endfor %}" data-filter-processes="{% for process in relatedProcesses %}{{ process.data.uuid }},{% endfor %}">
    <div class="card__content">
        <h3>
            <a class="card__title" href="{{ barrier.url }}">
                {{ barrier.data.title }}
            </a>
        </h3>
        {% if barrier.data.problem %}
            <div class="card__heading-image">
                {% include 'svg/problem.svg' %}
                <h4>
                    {% __ 'barriers-problem' %}
                </h4>
            </div>
            {{ barrier.data.problem | markdown | safe }}
        {% endif %}
        {% if collections["strategies-and-tips_" + lang] | find("data.barriers", barrier.data.uuid) | length > 0 %}
            <div class="card__heading-image">
                {% include 'svg/fix.svg' %}
                <h4>
                    {% __ 'barriers-fix' %}
                </h4>
            </div>
            <ul>
                {% for strategy in collections["strategies-and-tips_" + lang] | findAll('data.barriers', barrier.data.uuid) %}
                    <li>{{ strategy.data.title }}</li>
                {% endfor %}
            </ul>
        {% endif %}
    </div>
</div>
